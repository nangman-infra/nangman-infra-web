# Deployment environment for docker-compose.yml

FRONTEND_URL=https://nangman.cloud
MATTERMOST_WEBHOOK_URL=https://mattermost.nangman.cloud/hooks/replace-with-real-webhook

# External CMS (NAS Directus)
DIRECTUS_URL=http://192.168.10.3:8055
DIRECTUS_TOKEN=replace-with-directus-token

# Monitoring
KUMA_URL=http://172.16.0.14:3001
KUMA_STATUS_PAGE_SLUG=nangman

# UPS monitoring
NUT_SERVER_URL=192.168.10.3:3493
NUT_UPS_NAME=ups
NUT_USERNAME=replace-with-nut-username
NUT_PASSWORD=replace-with-nut-password

# Watchtower
WATCHTOWER_TOKEN=replace-with-watchtower-token
